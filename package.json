  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.3",
    "aws-sdk-client-mock": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
